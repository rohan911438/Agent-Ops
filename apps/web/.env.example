# Wallet-first auth (see docs/Architecture.md). Must match apps/api's
# AUTH_DISABLED / SESSION_SECRET_KEY.
AUTH_DISABLED=true
SESSION_JWT_SECRET=dev-insecure-secret-change-me

# Where to send users who don't have the OKX Wallet browser extension yet.
NEXT_PUBLIC_OKX_WALLET_DOWNLOAD_URL=https://www.okx.com/web3

# WalletConnect v2 fallback for every device without the OKX Wallet browser
# extension (mobile browsers, desktop without it installed) — see
# lib/wallet-connect.ts. Get a free project ID at https://cloud.reown.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# API
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# On-chain trust layer — used only for the "View verification record" link
# on a completed scan's Executive Report.
NEXT_PUBLIC_BASE_EXPLORER_URL=https://sepolia.basescan.org
