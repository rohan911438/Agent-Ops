# Wallet-first auth (see docs/Architecture.md). Must match apps/api's
# AUTH_DISABLED / SESSION_SECRET_KEY.
AUTH_DISABLED=true
SESSION_JWT_SECRET=dev-insecure-secret-change-me

# Where to send users who don't have the OKX Wallet browser extension yet.
NEXT_PUBLIC_OKX_WALLET_DOWNLOAD_URL=https://www.okx.com/web3

# API
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
