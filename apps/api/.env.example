# App
ENVIRONMENT=development
API_V1_PREFIX=/api/v1

# Database — local file, no server required.
# Path is relative to apps/api/ unless absolute.
DATABASE_URL=sqlite+aiosqlite:///./data/agentops.db

# Clerk (https://dashboard.clerk.com) — leave blank in local dev to disable auth checks
CLERK_JWKS_URL=
CLERK_ISSUER=
CLERK_WEBHOOK_SECRET=

# LLM provider abstraction — OpenAI is the only implemented provider today
OPENAI_API_KEY=

# CORS — comma-separated origins allowed to call the API
CORS_ORIGINS=http://localhost:3000
