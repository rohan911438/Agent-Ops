# App
ENVIRONMENT=development
API_V1_PREFIX=/api/v1

# Database — local file, no server required.
# Path is relative to apps/api/ unless absolute.
DATABASE_URL=sqlite+aiosqlite:///./data/agentops.db

# Wallet-first auth (see docs/Architecture.md). AUTH_DISABLED=true resolves
# every request to a fixed seeded dev-org/dev-user with no login needed —
# flip to false to exercise the real OKX Wallet challenge-response flow.
# SESSION_SECRET_KEY must match apps/web's SESSION_JWT_SECRET.
AUTH_DISABLED=true
SESSION_SECRET_KEY=dev-insecure-secret-change-me

# LLM provider abstraction — OpenAI is the only implemented provider today
OPENAI_API_KEY=

# CORS — comma-separated origins allowed to call the API
CORS_ORIGINS=http://localhost:3000
