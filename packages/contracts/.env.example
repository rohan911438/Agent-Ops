# Base Sepolia RPC endpoint. The public endpoint works for light use; swap in
# an Alchemy/Infura/QuickNode URL if you hit rate limits.
RPC_URL_BASE_SEPOLIA=https://sepolia.base.org

# Reserved for switching to Base Mainnet later — unused until Phase 5+ mainnet cutover.
RPC_URL_BASE_MAINNET=https://mainnet.base.org

# Deployer / owner key for Base Sepolia. NEVER commit a real value here.
# Generate a throwaway dev key with: npm run generate-wallet -w @agentops/contracts
PRIVATE_KEY=

# Basescan API key, used only by scripts/verify.ts. Optional — verification
# can also be done manually (see docs/VerificationGuide.md).
BASESCAN_API_KEY=
